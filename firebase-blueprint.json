{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the AetherScribe system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." }
      },
      "required": ["uid", "email"]
    },
    "Storybook": {
      "title": "Storybook",
      "description": "A generated illustrated storybook.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "heroSpecs": { "type": "object" },
        "setting": { "type": "string" },
        "plotArc": { "type": "object" },
        "artStyle": { "type": "string" },
        "pages": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorUid", "title", "pages", "createdAt"]
    },
    "DreamEntry": {
      "title": "DreamEntry",
      "description": "A recorded and analyzed dream entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "transcript": { "type": "string" },
        "analysis": { "type": "object" },
        "imageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorUid", "transcript", "analysis", "createdAt"]
    },
    "MoodCheckIn": {
      "title": "MoodCheckIn",
      "description": "A user's emotional state check-in.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "mood": { "type": "string" },
        "element": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorUid", "mood", "element", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/users/{userId}/storybooks/{storybookId}": {
      "schema": "Storybook",
      "description": "User's generated storybooks."
    },
    "/users/{userId}/dreams/{dreamId}": {
      "schema": "DreamEntry",
      "description": "User's dream journal entries."
    },
    "/users/{userId}/moods/{moodId}": {
      "schema": "MoodCheckIn",
      "description": "User's emotional check-ins."
    }
  }
}
